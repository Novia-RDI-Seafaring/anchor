# Backend Environment Variables (Python/Pydantic AI)
# Copy this file to .env and fill in your values

# Azure OpenAI configuration
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=your_chat_deployment
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_API_VERSION=2025-03-01-preview

# LLM model configuration
LLM_MODEL=gpt-4o-mini

# Provider selection
DEFAULT_PROVIDER=azure
DEFAULT_MODEL=azure:gpt-4.1-nano

# Ollama Model
# DEFAULT_PROVIDER=ollama
# DEFAULT_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://host.docker.internal:11434 # Ollama Connection (adjust based on your Docker setup)

# RAG Configuration
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50
# TOP_K_RESULTS=5

# Server Configuration
# HOST=0.0.0.0
PORT=8001
ALLOWED_ORIGINS=http://localhost:3000

# Write-route guard
# Local development allows unsafe writes from loopback by default.
# For shared or public deployments, set a key and disable unsafe local writes.
ANCHOR_WRITE_API_KEY=
ALLOW_UNSAFE_LOCAL_WRITES=true

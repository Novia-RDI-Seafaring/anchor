# Backend Environment Variables (Python/Pydantic AI)
# Copy this file to .env and fill in your values

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY= your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your_azure_openai_endpoint_here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT= my-o4-mini # your deployment name
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large # text-embedding-ada-002

# OpenAI Configuration
OPENAI_API_KEY=None # set your openai key here
#OPENAI_API_VERSION=2024-12-01-preview
OPENAI_API_VERSION=2025-03-01-preview

# LLM Model Configuration
LLM_MODEL=gpt-4o-mini

# Provider Selection (optional)
DEFAULT_PROVIDER=azure  # or "" openai
DEFAULT_MODEL=azure:gpt-4.1-nano  #openai:gpt-4o  # or your preferred model

# Ollama Model
# DEFAULT_PROVIDER=ollama
# DEFAULT_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://host.docker.internal:11434 # Ollama Connection (adjust based on your Docker setup)

# Logfire (Observability)
LOGFIRE_TOKEN=None

# Vector Database (if using Supabase)
# DATABASE_URL=postgresql://user:pass@host:port/dbname
# VECTOR_DB_COLLECTION=documents

PGVECTOR_HOST=localhost
PGVECTOR_PORT=6543
PGVECTOR_DB=postgres
PGVECTOR_USER=postgres.1234 # postgres.1234 should correspond to username.tenant name
PGVECTOR_PASSWORD=admin123
PGSSLMODE=disable

# Supabase API
SUPABASE_URL=http://localhost:6543 #7000
SERVICE_ROLE_KEY=jghriuubkbkihijvb # You can get this from your Supabase project settings
# Langfuse Configuration
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com # or your self-hosted URL


# RAG Configuration
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50
# TOP_K_RESULTS=5

# Server Configuration
# HOST=0.0.0.0
PORT=8001

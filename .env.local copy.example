# Frontend Environment Variables (Next.js)
# Copy this file to .env.local and fill in your values

# Backend API URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# Optional: OpenAI API Key (if needed on frontend)
# NEXT_PUBLIC_OPENAI_API_KEY=your_openai_key_here

# Backend Environment Variables (FastAPI)
# These are NOT read by Next.js; set them in the backend environment (e.g. `backend/.env` or your shell).
#
# Skip re-ingesting duplicate content (useful for eval/data runs)
# SKIP_DUPLICATE_INGEST=1

# Anchor v2 — example environment configuration
#
# Copy to `.env` in this directory and fill in only the values you need.
# All settings are optional; safe defaults are baked in. See README.md
# for flags and environment variables supported by the current CLI.

# ── HTTP CORS ───────────────────────────────────────────────────────────
# Select the server address and data directory using `anchor serve --host`,
# `--port`, and `--data-dir`. The API is unauthenticated; do not bind it to a
# network interface unless it is behind your own authentication layer.
#
# Extra origins allowed by CORS. The Vite dev server origins
# (http://localhost:5173, http://127.0.0.1:5173) are always allowed.
# ANCHOR_CORS_ORIGINS=https://anchor.example.com

# ── OpenAI-compatible LLMs ──────────────────────────────────────────────
# Vision-LLM gold extraction + polish. Either real OpenAI or any
# compatible endpoint (Azure OpenAI, Ollama, vLLM, LM Studio).
# ANCHOR_OPENAI_API_KEY=sk-...
# ANCHOR_OPENAI_BASE_URL=https://api.openai.com/v1
# ANCHOR_POLISH_MODEL=gpt-5.4
# ANCHOR_REGION_MODEL=gpt-5.4

# ── Embeddings ──────────────────────────────────────────────────────────
# Default is a local sentence-transformers model (BAAI/bge-small-en-v1.5).
# ANCHOR_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── PDF rendering ───────────────────────────────────────────────────────
# DPI for the silver-layer page images and bbox crops. Higher = sharper
# but slower + larger files.
# ANCHOR_DPI=150

# ── FMU extension (optional) ────────────────────────────────────────────
# Set to 1 ONLY if you want the synthetic-output offline demo runtime
# instead of the real FMPy-backed runtime. Every result returned by the
# demo runtime is stamped synthetic=true.
# ANCHOR_FMU_DEMO=0
